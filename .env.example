# =============================================================================
# Blocksize Capital MCP Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# --- Blocksize Capital API ---
BLOCKSIZE_API_KEY=your_blocksize_api_key_here
BLOCKSIZE_BASE_URL=https://data.blocksize.capital/marketdata/v1

# --- x402 Payment — Solana (Primary) ---
# Your Solana wallet address to receive USDC payments
X402_SOLANA_WALLET_ADDRESS=YourSolanaWalletAddressHere

# Solana mainnet CAIP-2 identifier
X402_SOLANA_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# USDC SPL Token address on Solana mainnet
X402_SOLANA_USDC_ADDRESS=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# --- x402 Payment — Base L2 (Fallback) ---
# Your EVM wallet address to receive USDC on Base
X402_EVM_WALLET_ADDRESS=0xYourBaseWalletAddressHere

# Base mainnet CAIP-2 identifier
X402_BASE_NETWORK=eip155:8453

# USDC on Base mainnet
X402_BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# --- Facilitator ---
X402_FACILITATOR_URL=https://x402.org/facilitator

# --- Tiered Pricing (USDC per call) ---
# Discovery tools:          FREE
PRICE_CORE_CRYPTO=0.002
PRICE_EXTENDED_CRYPTO=0.004
PRICE_TRADFI=0.005
PRICE_EQUITIES=0.008
PRICE_ANALYTICS=0.008

# --- Server Configuration ---
RESOURCE_SERVER_PORT=8402
MCP_TRANSPORT=stdio
MCP_SERVER_PORT=8403
LOG_LEVEL=INFO
